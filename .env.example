# AM Platform .env 範例(實際 .env 不進 git)
# 一支 OA / 一個 webhook 是唯一入口;各租戶機密以其 envPrefix 前綴存於此。

# ── 平台級(全域,共用)──────────────────────────────
PORT=3000

# LINE(共用同一支 OA:葉小蝸 AI 小幫手)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Notion(平台一組 integration token;隔離守衛用各租戶母頁限制範圍)
NOTION_TOKEN=
NOTION_VERSION=2025-09-03

# Google Drive(全域 OAuth;各租戶用自己的 <PREFIX>_DRIVE_ROOT_FOLDER_ID)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# AI 金鑰(共用)
ANTHROPIC_API_KEY=
ASSEMBLYAI_API_KEY=
GEMINI_API_KEY=
MINIMAX_API_KEY=
AMCORE_AI_PROVIDER=
AMCORE_AI_JUDGE_MODEL=

# Portal / 排程授權
AMCORE_QUEUE_ACCESS_KEY=
AMCORE_PORTAL_PIN=

# ── 租戶:工程(engineering，envPrefix=ENG，＝原 BuildAM 頁，頁不變)──
ENG_NOTION_PARENT_PAGE_ID=
ENG_MESSAGES_DATA_SOURCE_ID=
ENG_GROUP_BINDINGS_DATA_SOURCE_ID=
ENG_ATTACHMENTS_DATA_SOURCE_ID=
ENG_PROJECTS_DATA_SOURCE_ID=
ENG_SPACES_DATA_SOURCE_ID=
ENG_WORK_ITEMS_DATA_SOURCE_ID=
ENG_FEEDBACK_TICKETS_DATA_SOURCE_ID=
ENG_CHANGE_ORDERS_DATA_SOURCE_ID=
ENG_MEETINGS_DATA_SOURCE_ID=
ENG_TASKS_DATA_SOURCE_ID=
ENG_BUDGETS_DATA_SOURCE_ID=
ENG_CONTRACTS_DATA_SOURCE_ID=
ENG_DRIVE_ROOT_FOLDER_ID=
# (選用)per-tenant LINE 覆寫;預設用全域那支 OA
# ENG_LINE_CHANNEL_ACCESS_TOKEN=
# ENG_LINE_CHANNEL_SECRET=

# ── 租戶:森在(senzai，envPrefix=SENZAI，＝ Notion「AI」頁)──
SENZAI_NOTION_PARENT_PAGE_ID=
SENZAI_MESSAGES_DATA_SOURCE_ID=
SENZAI_GROUP_BINDINGS_DATA_SOURCE_ID=
SENZAI_MEETINGS_DATA_SOURCE_ID=
SENZAI_TASKS_DATA_SOURCE_ID=
SENZAI_DRIVE_ROOT_FOLDER_ID=
