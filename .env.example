# AM Platform .env 範例(實際 .env 不進 git)
# 一支 OA / 一個 webhook 是唯一入口;各租戶機密以其 envPrefix 前綴存於此。

# ── 平台級(全域,共用)──────────────────────────────
PORT=3000

# LINE(共用同一支 OA:葉小蝸 AI 小幫手)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Notion(平台一組 integration token;隔離守衛用各租戶母頁限制範圍)
NOTION_TOKEN=
NOTION_VERSION=2025-09-03

# Google Drive(全域 OAuth;各租戶用自己的 <PREFIX>_DRIVE_ROOT_FOLDER_ID)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# AI 金鑰(平台預設；租戶可用 <PREFIX>_* 覆寫)
ANTHROPIC_API_KEY=
ASSEMBLYAI_API_KEY=
GEMINI_API_KEY=
MINIMAX_API_KEY=
AMCORE_AI_PROVIDER=
AMCORE_AI_JUDGE_MODEL=

# LLM 備援鏈(core/llm.js)。留空 = minimax,gemini,anthropic。
# 鏈序即成本閥門:排前面的先被呼叫;沒設金鑰的後端自動略過。
# 需要看圖的呼叫(附件解析)只會交給看得見圖的後端。
AMCORE_LLM_CHAIN=
MINIMAX_MODEL=
ANTHROPIC_MODEL=
AMCORE_LLM_GEMINI_MODEL=
# MiniMax 的視覺能力看型號:M3 看得見圖、M2 看不見(自動依型號名判斷)。
# 換型號若判錯,用 1/0 手動覆寫。改完請跑 node scripts/check-llm.mjs 實測。
AMCORE_LLM_MINIMAX_VISION=

# per-call 鏈序 profile:呼叫端用 { profile: 'quality' } 指名,不必知道鏈長怎樣。
#   quality — 長逐字稿、要品質(meetings)。AssemblyAI LLM Gateway 轉售 Claude/GPT/Gemini。
#   cheap   — 短 prompt、每則訊息都跑(triage)。＝ AMCORE_LLM_CHAIN,留空即預設鏈。
# ⚠️ ASSEMBLYAI_API_KEY 一存在,assemblyai 後端就 available。它「不在」預設鏈是刻意的:
#    否則每則 LINE 訊息初判都會去打 Claude。
# ⚠️ 韌性:轉寫已押在 AssemblyAI,quality 鏈第二順位必須是「直連 Gemini(自己的金鑰)」,
#    不是 Gateway 轉售的 gemini —— 否則 AssemblyAI 一掛,轉寫與摘要同時陣亡。
AMCORE_LLM_ASSEMBLYAI_MODEL=
AMCORE_LLM_CHAIN_QUALITY=
AMCORE_LLM_CHAIN_CHEAP=

# 時間界線。留空 = 單一請求 120s、整條鏈 300s。
# ⚠️ timeout 綁的是「單一請求」,綁不住整條鏈(3 家後端 × 最多 3 次 = 最多 9 個請求)。
#    使用者看得見的等待上限是 BUDGET_MS,不是 TIMEOUT_MS。
# 120s 的由來:真實會議 prompt + 27,000 字逐字稿實測,最慢的模型是 94s。
# 要吃長影片/大 PDF 請由呼叫端傳 timeoutMs,不要調高這裡。
AMCORE_LLM_TIMEOUT_MS=
AMCORE_LLM_BUDGET_MS=

# Portal / 排程授權
AMCORE_QUEUE_ACCESS_KEY=
# Portal 與 Core 必須設定相同的高熵伺服器金鑰（Portal 端名稱 AM_PLATFORM_SERVICE_TOKEN）
AMCORE_PORTAL_SERVICE_TOKEN=
AMCORE_PORTAL_ME_ENDPOINT=https://rental.hozorental.com/api/me
AMCORE_PORTAL_HANDOFF_ENDPOINT=https://rental.hozorental.com/api/am-sso/consume
AMCORE_PORTAL_VERIFY_ENDPOINT=https://rental.hozorental.com/api/am-sso/verify
# shadow → 完成帳號審核後改 enforce；異常回復用 owner-only，不可退回租戶全開
AMCORE_GROUP_AUTHZ_MODE=shadow
# 日常 PIN 預設關閉；人工緊急啟用時最長 900 秒
AMCORE_ENABLE_EMERGENCY_PIN=0
AMCORE_EMERGENCY_PIN_TTL_SECONDS=900
AMCORE_PORTAL_PIN=
AMCORE_PUBLIC_BASE_URL=
AMCORE_HOME_TENANT=engineering
AMCORE_ESCALATION_DAYS=2
AMCORE_REMINDER_HOUR=9
AMCORE_ESCALATION_OWNER=

# ── 租戶:工程(engineering，envPrefix=ENG，＝原 BuildAM 頁，頁不變)──
ENG_NOTION_PARENT_PAGE_ID=
ENG_MESSAGES_DATA_SOURCE_ID=
ENG_GROUP_BINDINGS_DATA_SOURCE_ID=
ENG_ATTACHMENTS_DATA_SOURCE_ID=
ENG_PROJECTS_DATA_SOURCE_ID=
ENG_SPACES_DATA_SOURCE_ID=
ENG_WORK_ITEMS_DATA_SOURCE_ID=
ENG_FEEDBACK_TICKETS_DATA_SOURCE_ID=
ENG_CHANGE_ORDERS_DATA_SOURCE_ID=
ENG_MEETINGS_DATA_SOURCE_ID=
ENG_TASKS_DATA_SOURCE_ID=
ENG_BUDGETS_DATA_SOURCE_ID=
ENG_CONTRACTS_DATA_SOURCE_ID=
ENG_DRIVE_ROOT_FOLDER_ID=
# 工程租戶的後台、提醒、行事曆與 AI（未填則回退 AMCORE_/全域值）
ENG_QUEUE_ACCESS_KEY=
ENG_PORTAL_PIN=
ENG_PUBLIC_BASE_URL=
ENG_ESCALATION_DAYS=2
ENG_REMINDER_HOUR=9
ENG_ESCALATION_OWNER=
ENG_CAL_ZS=
ENG_CAL_HZ=
ENG_AI_PROVIDER=
ENG_AI_JUDGE_MODEL=
ENG_MEETING_MODEL=gemini-2.5-flash
ENG_ANTHROPIC_API_KEY=
ENG_ASSEMBLYAI_API_KEY=
ENG_GEMINI_API_KEY=
ENG_MINIMAX_API_KEY=
ENG_MINIMAX_API_BASE_URL=
# 僅供舊設定盤點；AM Platform 正式運行仍只使用上方全域 LINE_*，不得填成另一支 OA。
# ENG_LINE_CHANNEL_ACCESS_TOKEN=
# ENG_LINE_CHANNEL_SECRET=

# ── 租戶:森在(forest，envPrefix=FOREST，＝ Notion「AI」頁)──
FOREST_NOTION_PARENT_PAGE_ID=
FOREST_MESSAGES_DATA_SOURCE_ID=
FOREST_GROUP_BINDINGS_DATA_SOURCE_ID=
FOREST_MEETINGS_DATA_SOURCE_ID=
FOREST_TASKS_DATA_SOURCE_ID=
FOREST_DRIVE_ROOT_FOLDER_ID=
