{
  "id": "AM-IMP-2026.0608.20",
  "name": "SevenAM 08:00 Google Calendar agenda section",
  "type": "Project-local reporting integration",
  "portable": false,
  "requiresDatabases": [
    "SEVEN_TASKS_DATA_SOURCE_ID",
    "SEVEN_MESSAGES_DATA_SOURCE_ID",
    "SEVEN_PROGRESS_REPORTS_DATA_SOURCE_ID",
    "SEVEN_RESPONSIBILITY_DATA_SOURCE_ID"
  ],
  "requiresEnv": [
    "NOTION_TOKEN",
    "SEVEN_GOOGLE_CALENDAR_EVENTS_JSON or SEVEN_GOOGLE_CALENDAR_EVENTS_FILE"
  ],
  "requiresScripts": [
    "scripts/generate-0800-daily-report-preview.js"
  ],
  "installTargets": ["SEVEN_AM"],
  "excludedTargets": ["HOZO_AM"],
  "dataIsolation": {
    "canCopyCode": false,
    "canCopySchema": false,
    "canCopyData": false,
    "canCopySecrets": false
  },
  "definitionOfDone": [
    "SevenAM 08:00 report includes a 今天的行程安排 section",
    "The Calendar section displays real Calendar input when provided",
    "The report shows an explicit not-connected state when Calendar input is unavailable",
    "SevenAM .env.example documents Calendar input variables",
    "HOZO AM is not changed"
  ]
}
