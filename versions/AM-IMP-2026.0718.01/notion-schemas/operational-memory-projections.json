    ],
    "sourceLocationClickableWhenAvailable": true,
    "legacySourceOriginalPropertyAuthoritative": false
  },
  "relationRules": [
    "Every task relates to exactly one tenant-local project and at least one tenant-local goal before it becomes formal.",
    "Every task, goal, decision, and verified knowledge item relates to one or more tenant-local source events.",
    "Every event carries auditable source evidence even when a Notion relation cannot represent every source type.",
    "Every LINE-created task carries the tenant-local group binding relation.",
    "Meeting checkbox tasks relate to the meeting record and preserve nearby discussion in evidence.",
    "Self-relations for task parent-child or decision supersession remain inside the same tenant data source.",
    "A relation target is resolved from TenantContext logical handles, never from model or browser input."
  ],
  "forbiddenPatterns": [
    "one shared production Notion database containing live records from multiple AM tenants",
    "hard-coded production data-source IDs in AMCore",
    "task creation without source evidence and project goal relation",
    "overwriting old task evidence instead of appending a new record",
    "deleting superseded events or decisions",
    "treating candidate knowledge as official policy",
    "using Notion page content as the only canonical event history",
    "trusting a user-editable Tenant Key, entity ID, version, relation, or operator field"
  ]
}
