{
  "schemaVersion": 1,
  "id": "am-operational-memory-notion-projections",
  "role": "Human-readable, review, approval, and workflow projections of tenant-local operational memory. Notion is not the cross-tenant canonical event store and is never a substitute for source evidence.",
  "tenantIsolation": {
    "allDataSourcesProjectLocal": true,
    "allDataSourceHandlesResolvedFromTenantContext": true,
    "productionIdsStoredInPackage": false,
    "relationsMustStayInsideTenantParent": true,
    "tenantKeyAuditPropertyRequired": true,
    "tenantKeyPropertyMutableByUser": false,
    "notionRequestsMustUseTenantLockedAdapter": true,
    "userReadsAndWritesAlsoRequireAccessContext": true,
    "crossTenantRollupsRelationsAndCopiesForbidden": true
  },
  "sourceOfTruth": {
    "rawEvidence": "Project-local SourceStore and existing LINE, meeting, report, file, or linked-page records.",
    "eventHistory": "Project-local append-only EventStore.",
    "currentState": "Project-local versioned ProjectionStore.",
    "notionRole": [
      "human review",
      "task and project views",
      "decision approval",
      "knowledge approval",
      "weekly summaries"
    ],
    "notionDirectEdits": "Authorized human edits to controlled fields must be converted into tenant-local commands with actor, evidence, expected version, and rule trace before canonical state changes.",
    "notionMustNotAuthoritativelyOverwrite": [
      "raw source content",
      "event history",
      "task transition history",
      "supersession history",
      "tenant identity",
      "canonical entity IDs",
      "projection version"
    ]
  },
  "syncRules": {
    "direction": "canonical-to-notion by default; selected authorized review actions return as commands",
    "mechanism": "tenant-local idempotent outbox",
    "idempotencyKeyPattern": "{tenant_id}:{entity_type}:{entity_id}:{projection_version}",
    "publishFailureBehavior": "Keep canonical state committed, record the failure, and retry the tenant-local outbox.",
    "notionVersionBehindBehavior": "Republish the latest canonical projection.",
    "notionVersionAheadBehavior": "Do not trust or overwrite canonical state; create a review conflict.",
    "deletionBehavior": "Archive or mark the projection according to canonical retention state; never silently delete event or evidence history."
  },
  "statusMappings": {
    "taskLifecycle": {
      "candidate": "待確認",
      "pending": "待處理",
      "in_progress": "處理中",
      "waiting": "等待他人",
      "pending_completion_confirmation": "待完成確認",
      "completed": "已完成",
      "cancelled": "已取消",
      "no_action": "無須處理"
    },
    "taskConfirmation": {
      "pending": "待確認",
      "confirmed": "已確認",
      "rejected": "不成立"
    },
    "taskFormalization": {
      "candidate": "候選控制項",
      "formal": "正式總控任務",
      "rejected": "不納入總控"
    },
    "decisionStatus": {
      "draft": "草案",
      "active": "目前有效",
      "superseded": "已被取代",
      "revoked": "已撤銷"
    },
    "knowledgeStatus": {
      "candidate": "候選知識",
      "verified": "正式知識",
      "deprecated": "已停用",
      "expired": "已過期"
    },
    "projectAndGoalStatus": {
      "candidate": "待確認",
      "active": "進行中",
      "on_hold": "暫停",
      "completed": "已完成",
      "cancelled": "已取消"
    },
    "derivedFlags": {
      "overdue": "逾期",
      "blocked": "受阻"
    }
  },
